<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="hust.soict.globalict.aims.screen.customer.controller.CartController"
            prefWidth="1024" prefHeight="768">
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-margin: 20 20 0 20; -fx-padding: 10;">
            <Label text="CART"
                   style="-fx-font-size: 50px; -fx-text-fill: #004cff;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="View Store" onAction="#btnViewStorePressed"
                    prefWidth="100" prefHeight="50"/>
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" style="-fx-margin: 20 20 0 20;">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 0 10 0; -fx-spacing: 10;">
                <Label text="Filter"/>
                <TextField fx:id="tfFilter"/>
                <RadioButton fx:id="radioBtnFilterId" text="By ID" selected="true">
                    <toggleGroup>
                        <ToggleGroup fx:id="filterCategory"/>
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="radioBtnFilterTitle" text="By Title"
                             toggleGroup="$filterCategory"/>
            </HBox>
            <TableView fx:id="tblMedia" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMediaId"       text="ID"       prefWidth="60"/>
                    <TableColumn fx:id="colMediaTitle"    text="Title"    prefWidth="220"/>
                    <TableColumn fx:id="colMediaCategory" text="Category" prefWidth="150"/>
                    <TableColumn fx:id="colMediaCost"     text="Cost"     prefWidth="100"/>
                </columns>
            </TableView>
            <HBox alignment="TOP_RIGHT" style="-fx-padding: 10 0 0 0; -fx-spacing: 20;">
                <Button fx:id="btnPlay" text="Play" onAction="#btnPlayPressed"
                        prefWidth="60" visible="false"/>
                <Button fx:id="btnRemove" text="Remove" onAction="#btnRemovePressed"
                        prefWidth="60" visible="false"/>
            </HBox>
        </VBox>
    </center>
    <bottom>
        <VBox alignment="TOP_CENTER" spacing="30" prefHeight="200">
            <HBox alignment="CENTER" prefWidth="-1.0" prefHeight="-1.0">
                <Label text="Total: " style="-fx-font-size: 24px; -fx-font-weight: bold;
                                             -fx-padding: 0 10 0 0;"/>
                <Label fx:id="costLabel" text="0 $"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            </HBox>
            <Button text="Place Order" onAction="#btnPlaceOrderPressed"
                    style="-fx-font-size: 24px; -fx-font-weight: bold;
                           -fx-text-fill: white; -fx-background-color: #004cff;"/>
        </VBox>
    </bottom>
</BorderPane>
